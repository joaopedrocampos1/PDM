{
  "info": {
    "_postman_id": "a6d39b60-d77a-4b8b-8d52-6c5f55f63054",
    "name": "Gestao Financeira API",
    "description": "Collection para testar a API de gestao financeira. Execute as requisicoes em ordem: health-check, login, categorias, transacoes e validacoes. O login salva o token em {{apiToken}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Health-check",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('API saudavel', function () {",
              "  pm.expect(json.ok).to.eql(true);",
              "  pm.expect(json.name).to.eql('gestao-financeira-api');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"aluno@iesb.com\",\n  \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Retorna token e usuario', function () {",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json.user).to.have.property('email', 'aluno@iesb.com');",
              "});",
              "",
              "pm.collectionVariables.set('apiToken', json.token);",
              "pm.collectionVariables.set('userId', json.user.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "03 - Perfil autenticado",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{apiToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/auth/me"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Retorna usuario do token', function () {",
              "  pm.expect(json.user).to.have.property('email', 'aluno@iesb.com');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 - Listar categorias",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{apiToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/categories"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const categories = pm.response.json();",
              "",
              "pm.test('Retorna lista de categorias', function () {",
              "  pm.expect(categories).to.be.an('array');",
              "  pm.expect(categories.length).to.be.at.least(5);",
              "});",
              "",
              "const income = categories.find(function (category) {",
              "  return category.name === 'income';",
              "});",
              "",
              "pm.test('Tem categoria padrao income', function () {",
              "  pm.expect(income).to.exist;",
              "});",
              "",
              "if (income && income.id) {",
              "  pm.collectionVariables.set('incomeCategoryId', income.id);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "05 - Criar categoria",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{apiToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"health\",\n  \"displayName\": \"Sa\\u00fade\",\n  \"icon\": \"favorite\",\n  \"background\": \"#FFB6B6\",\n  \"isIncome\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/categories"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Categoria criada', function () {",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('name', 'health');",
              "  pm.expect(json).to.have.property('isDefault', false);",
              "});",
              "",
              "pm.collectionVariables.set('categoryId', json.id);"
            ]
          }
        }
      ]
    },
