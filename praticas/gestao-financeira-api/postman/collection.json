    {
      "name": "09 - Criar transacao",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{apiToken}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"description\": \"Salario de outubro\",\n  \"value\": 3500.5,\n  \"date\": \"2026-04-29\",\n  \"categoryId\": \"{{incomeCategoryId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/transactions"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "",
              "pm.test('Transacao criada com categoria', function () {",
              "  pm.expect(json).to.have.property('id');",
              "  pm.expect(json).to.have.property('description', 'Salario de outubro');",
              "  pm.expect(json.category).to.have.property('id', pm.collectionVariables.get('incomeCategoryId'));",
              "});",
              "",
              "pm.collectionVariables.set('transactionId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "10 - Listar transacoes",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{apiToken}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/transactions"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const transactions = pm.response.json();",
              "const transactionId = pm.collectionVariables.get('transactionId');",
              "",
              "pm.test('Retorna lista de transacoes', function () {",
              "  pm.expect(transactions).to.be.an('array');",
              "});",
              "",
              "pm.test('Inclui a transacao criada', function () {",
              "  pm.expect(transactions.some(function (transaction) {",
              "    return transaction.id === transactionId && transaction.category;",
              "  })).to.eql(true);",
              "});"
            ]
          }
        }
      ]
    },
